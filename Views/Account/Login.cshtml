<h2>Login</h2>

<form method="post">

    <div>
        <label>Email</label>
        <input type="email" name="email" required />
    </div>

    <div>
        <label>Password</label>
        <input type="password" name="password" required />
    </div>

    <br />

    <button type="submit">Login</button>

</form>

<p>@ViewBag.Message</p>

<a href="/Account/Register">Create New Account</a>